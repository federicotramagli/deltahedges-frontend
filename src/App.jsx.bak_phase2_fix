      current.map((item) =>
        item.id === slotDraft.id
          ? (() => {
              const updatedSlot = {
                ...item,
                ...slotDraft,
                propEquity: Number(slotDraft.propEquity),
                brokerEquity: Number(slotDraft.brokerEquity),
