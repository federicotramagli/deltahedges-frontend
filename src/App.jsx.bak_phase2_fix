    setNotifications((current) => [
      {
        id: `notice_${Date.now()}`,
        title: `Export ${panel.source ?? "dashboard"} richiesto`,
        body: `Scope ${exportDraft.scope.replaceAll("_", " ")} con opzioni personalizzate.`,
      },
      ...current,
    ]);
    closePanel();
  }

  function toggleSlotPower(slotId) {
    const slot = slots.find((item) => item.id === slotId);
    if (!slot) return;

    setSelectedSlotId(slot.id);

    if (slot.challengeState === "ATTIVA") {
      const nextState =
        hasPropConnection(slot) &&
        hasBrokerConnection(slot) &&
        hasStrategyParameters(slot)
          ? "PRONTA"
          : "BOZZA";

      setSlots((current) =>
        current.map((item) =>
          item.id === slot.id
            ? {
                ...item,
                challengeState: nextState,
                updatedAt: nowHourMinute(),
              }
            : item,
        ),
      );

      setNotifications((current) => [
        {
          id: `notice_${Date.now()}`,
          title: `${slot.slot} spento`,
          body: "Lo slot e stato fermato. Puoi riattivarlo quando vuoi dalla card.",
        },
        ...current,
      ]);
      return;
    }

    if (!hasPropConnection(slot) || !hasBrokerConnection(slot)) {
      openSlotConnections(slot.id);
      return;
    }

    if (!hasStrategyParameters(slot)) {
      openSlotParameters(slot.id);
      return;
    }

    setSlots((current) =>
      current.map((item) =>
        item.id === slot.id
          ? {
              ...item,
              challengeState: "ATTIVA",
              status: normaliseStatus(slot.phase),
              updatedAt: nowHourMinute(),
            }
          : item,
      ),
    );

    setNotifications((current) => [
      {
        id: `notice_${Date.now()}`,
        title: `${slot.slot} acceso`,
        body: `Lo slot ${slot.challenge} e stato portato online dal toggle rapido.`,
      },
      ...current,
    ]);
  }

