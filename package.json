{
  "name": "pairgrid-landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm run dev -w @deltahedge/api",
    "dev:worker": "npm run dev -w @deltahedge/worker",
    "build": "vite build",
    "build:web": "vite build",
    "build:shared": "npm run build -w @deltahedge/shared",
    "build:api": "npm run build -w @deltahedge/shared && npm run build -w @deltahedge/api",
    "build:worker": "npm run build -w @deltahedge/shared && npm run build -w @deltahedge/worker",
    "preview": "vite preview",
    "typecheck:server": "tsc -b packages/shared apps/api apps/worker",
    "test:server": "tsx --test packages/shared/src/**/*.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.100.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.8.1",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
